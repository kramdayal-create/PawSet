# ===========================================================================
# PawSet environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# ===========================================================================

# --- App ---------------------------------------------------------------------
# Public base URL of the app (used for share links).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth is bypassed (demo mode) unless this is explicitly set to false.
BYPASS_AUTH=true

# --- Supabase ----------------------------------------------------------------
# Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key is SERVER-ONLY. Never import into client components.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Security ----------------------------------------------------------------
# 32+ byte secret used to sign share tokens.
# Generate with: openssl rand -base64 48
APP_SECRET=replace-with-a-long-random-secret
